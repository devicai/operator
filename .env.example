# Copy to .env and adjust for your deployment.
# Both files are gitignored except for this example.

# API key required when config.yml has auth.enabled: true.
# Generate one with: openssl rand -hex 32
SANDBOX_API_KEY=

# Optional overrides — defaults match config.yml.
# DATABASE_URI=mongodb://mongo:27017/devic-sandbox
# REDIS_URL=redis://redis:6379

# Optional host port overrides — defaults bind 127.0.0.1:3200 (app) and 127.0.0.1:5174 (frontend).
# PORT=3200
# FRONTEND_PORT=5174
